# Copy to .env. Never commit the populated .env file.
FDAI_ENVIRONMENT=local
FDAI_HOST=0.0.0.0
FDAI_PORT=3000
FDAI_LOG_LEVEL=INFO
FDAI_MODEL_PROVIDER=deterministic
FDAI_MODEL_NAME=offline-grounded-demo
FDAI_TOP_K=3

# Optional model providers
FDAI_OPENAI_API_KEY=
FDAI_ANTHROPIC_API_KEY=
FDAI_AZURE_AI_ENDPOINT=
FDAI_AZURE_AI_API_KEY=
FDAI_AWS_REGION=us-east-1
FDAI_GOOGLE_CLOUD_PROJECT=

# Salesforce connected-app / OAuth access (read-only by default)
FDAI_LIVE_INTEGRATIONS_ENABLED=false
FDAI_SALESFORCE_INSTANCE_URL=
FDAI_SALESFORCE_ACCESS_TOKEN=
FDAI_SALESFORCE_API_VERSION=v61.0
FDAI_ALLOW_SALESFORCE_WRITES=false

# Optional experiment tracking and telemetry
FDAI_ENABLE_LANGGRAPH=false
FDAI_ENABLE_MLFLOW=false
FDAI_MLFLOW_TRACKING_URI=file:./mlruns
FDAI_MLFLOW_EXPERIMENT=forward-deployed-ai-lab
FDAI_ENABLE_OPENTELEMETRY=false
